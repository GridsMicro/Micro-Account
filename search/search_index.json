als/#_3","title":"\u0e40\u0e02\u0e49\u0e32\u0e2b\u0e19\u0e49\u0e32\u0e1a\u0e31\u0e19\u0e17\u0e36\u0e01","text":"<p>\u0e44\u0e1b\u0e17\u0e35\u0e48 \u0e2a\u0e21\u0e38\u0e14\u0e23\u0e32\u0e22\u0e27\u0e31\u0e19 \u2192 \u0e04\u0e25\u0e34\u0e01 \"\u0e25\u0e07\u0e1a\u0e31\u0e0d\u0e0a\u0e35\u0e43\u0e2b\u0e21\u0e48\"</p>"},{"location":"docs/accounting/journals/#_4","title":"\u0e01\u0e23\u0e2d\u0e01\u0e02\u0e49\u0e2d\u0e21\u0e39\u0e25\u0e2b\u0e25\u0e31\u0e01","text":"\u0e0a\u0e48\u0e2d\u0e07 \u0e01\u0e23\u0e2d\u0e01\u0e2d\u0e30\u0e44\u0e23 \u0e15\u0e31\u0e27\u0e2d\u0e22\u0e48\u0e32\u0e07 \u0e27\u0e31\u0e19\u0e17\u0e35\u0e48\u0e40\u0e01\u0e34\u0e14\u0e23\u0e32\u0e22\u0e01\u0e32\u0e23 \u0e27\u0e31\u0e19\u0e17\u0e35\u0e48\u0e08\u0e48\u0e32\u0e22\u0e40\u0e07\u0e34\u0e19\u0e08\u0e23\u0e34\u0e07 16/03/2026 \u0e40\u0e25\u0e02\u0e17\u0e35\u0e48\u0e43\u0e1a\u0e40\u0e2a\u0e23\u0e47\u0e08 \u0e40\u0e25\u0e02\u0e2d\u0e49\u0e32\u0e07\u0e2d\u0e34\u0e07\u0e40\u0e2d\u0e01\u0e2a\u0e32\u0e23 (\u0e44\u0e21\u0e48\u0e1a\u0e31\u0e07\u0e04\u0e31\u0e1a) TH001234 \u0e2b\u0e21\u0e32\u0e22\u0e40\u0e2b\u0e15\u0e38 \u0e2d\u0e18\u0e34\u0e1a\u0e32\u0e22\u0e2a\u0e31\u0e49\u0e19\u0e46 \u0e04\u0e48\u0e32\u0e2a\u0e48\u0e07\u0e1e\u0e31\u0e2a\u0e14\u0e38\u0e25\u0e39\u0e01\u0e04\u0e49\u0e32 \u0e21\u0e35.\u0e04. 69"},{"location":"docs/accounting/journals/#_5","title":"\u0e01\u0e23\u0e2d\u0e01\u0e23\u0e32\u0e22\u0e01\u0e32\u0e23\u0e1a\u0e31\u0e0d\u0e0a\u0e35","text":"<p>\u0e2b\u0e25\u0e31\u0e01\u0e07\u0e48\u0e32\u0e22\u0e46</p> <ul> <li>\u0e1a\u0e23\u0e23\u0e17\u0e31\u0e14 \"\u0e23\u0e32\u0e22\u0e08\u0e48\u0e32\u0e22\" \u2192 \u0e0a\u0e37\u0e48\u0e2d\u0e04\u0e48\u0e32\u0e43\u0e0a\u0e49\u0e08\u0e48\u0e32\u0e22 \u0e40\u0e0a\u0e48\u0e19 <code>\u0e04\u0e48\u0e32\u0e44\u0e1b\u0e23\u0e29\u0e13\u0e35\u0e22\u0e4c</code>, <code>\u0e04\u0e48\u0e32\u0e19\u0e49\u0e33\u0e21\u0e31\u0e19</code>, <code>\u0e04\u0e48\u0e32\u0e42\u0e17\u0e23\u0e28\u0e31\u0e1e\u0e17\u0e4c</code></li> <li>\u0e1a\u0e23\u0e23\u0e17\u0e31\u0e14 \"\u0e08\u0e48\u0e32\u0e22\u0e2d\u0e2d\u0e01\u0e08\u0e32\u0e01\" \u2192 \u0e41\u0e2b\u0e25\u0e48\u0e07\u0e40\u0e07\u0e34\u0e19 \u0e40\u0e0a\u0e48\u0e19 <code>\u0e40\u0e07\u0e34\u0e19\u0e2a\u0e14</code>, <code>\u0e18\u0e19\u0e32\u0e04\u0e32\u0e23\u0e01\u0e2a\u0e34\u0e01\u0e23\u0e44\u0e17\u0e22</code></li> <li>\u0e17\u0e31\u0e49\u0e07\u0e2a\u0e2d\u0e07\u0e1d\u0e31\u0e48\u0e07\u0e15\u0e49\u0e2d\u0e07\u0e21\u0e35\u0e22\u0e2d\u0e14\u0e40\u0e17\u0e48\u0e32\u0e01\u0e31\u0e19 \u2705</li> </ul> <p>\u0e15\u0e31\u0e27\u0e2d\u0e22\u0e48\u0e32\u0e07: \u0e1a\u0e31\u0e19\u0e17\u0e36\u0e01\u0e04\u0e48\u0e32\u0e44\u0e1b\u0e23\u0e29\u0e13\u0e35\u0e22\u0e4c 69 \u0e1a\u0e32\u0e17 (\u0e08\u0e48\u0e32\u0e22\u0e40\u0e07\u0e34\u0e19\u0e2a\u0e14)</p> \u0e0a\u0e37\u0e48\u0e2d\u0e1a\u0e31\u0e0d\u0e0a\u0e35 \u0e1b\u0e23\u0e30\u0e40\u0e20\u0e17 \u0e08\u0e33\u0e19\u0e27\u0e19 \u0e04\u0e48\u0e32\u0e44\u0e1b\u0e23\u0e29\u0e13\u0e35\u0e22\u0e4c\u0e41\u0e25\u0e30\u0e04\u0e48\u0e32\u0e02\u0e19\u0e2a\u0e48\u0e07 \ud83d\udcb8 \u0e23\u0e32\u0e22\u0e08\u0e48\u0e32\u0e22 69.00 \u0e40\u0e07\u0e34\u0e19\u0e2a\u0e14 \ud83c\udfe6 \u0e08\u0e48\u0e32\u0e22\u0e2d\u0e2d\u0e01\u0e08\u0e32\u0e01 69.00"},{"location":"docs/accounting/journals/#google-drive","title":"\u0e41\u0e19\u0e1a\u0e43\u0e1a\u0e40\u0e2a\u0e23\u0e47\u0e08\u0e08\u0e32\u0e01 Google Drive","text":"<ol> <li>\u0e04\u0e25\u0e34\u0e01\u0e1b\u0e38\u0e48\u0e21 \"\u0e40\u0e25\u0e37\u0e2d\u0e01\u0e08\u0e32\u0e01 Google Drive\"</li> <li>Login \u0e14\u0e49\u0e27\u0e22 Google Workspace \u0e02\u0e2d\u0e07\u0e2d\u0e07\u0e04\u0e4c\u0e01\u0e23</li> <li>\u0e40\u0e25\u0e37\u0e2d\u0e01\u0e44\u0e1f\u0e25\u0e4c\u0e43\u0e1a\u0e40\u0e2a\u0e23\u0e47\u0e08 (PDF \u0e2b\u0e23\u0e37\u0e2d \u0e23\u0e39\u0e1b\u0e20\u0e32\u0e1e)</li> <li>\u0e23\u0e30\u0e1a\u0e1a\u0e08\u0e30\u0e41\u0e2a\u0e14\u0e07\u0e25\u0e34\u0e07\u0e04\u0e4c\u0e44\u0e1f\u0e25\u0e4c\u0e1e\u0e23\u0e49\u0e2d\u0e21\u0e01\u0e14\u0e40\u0e1b\u0e34\u0e14\u0e14\u0e39\u0e44\u0e14\u0e49\u0e17\u0e31\u0e19\u0e17\u0e35</li> </ol>"},{"location":"docs/accounting/journals/#_6","title":"\u0e1a\u0e31\u0e19\u0e17\u0e36\u0e01\u0e23\u0e32\u0e22\u0e01\u0e32\u0e23","text":"<p>\u0e40\u0e21\u0e37\u0e48\u0e2d\u0e22\u0e2d\u0e14\u0e17\u0e31\u0e49\u0e07\u0e2a\u0e2d\u0e07\u0e1d\u0e31\u0e48\u0e07\u0e40\u0e17\u0e48\u0e32\u0e01\u0e31\u0e19 \u0e23\u0e30\u0e1a\u0e1a\u0e08\u0e30\u0e41\u0e2a\u0e14\u0e07 \u2705 \u0e22\u0e2d\u0e14\u0e16\u0e39\u0e01\u0e15\u0e49\u0e2d\u0e07 \u0e01\u0e14\u0e1a\u0e31\u0e19\u0e17\u0e36\u0e01\u0e44\u0e14\u0e49\u0e40\u0e25\u0e22! \u0e08\u0e32\u0e01\u0e19\u0e31\u0e49\u0e19\u0e01\u0e14\u0e1b\u0e38\u0e48\u0e21 \"\u0e1a\u0e31\u0e19\u0e17\u0e36\u0e01\u0e23\u0e32\u0e22\u0e01\u0e32\u0e23\"</p>"},{"location":"docs/accounting/journals/#_7","title":"\u0e1b\u0e23\u0e30\u0e40\u0e20\u0e17\u0e23\u0e32\u0e22\u0e08\u0e48\u0e32\u0e22\u0e17\u0e35\u0e48\u0e1e\u0e1a\u0e1a\u0e48\u0e2d\u0e22","text":"\u0e1b\u0e23\u0e30\u0e40\u0e20\u0e17 \u0e0a\u0e37\u0e48\u0e2d\u0e1a\u0e31\u0e0d\u0e0a\u0e35\u0e17\u0e35\u0e48\u0e04\u0e27\u0e23\u0e43\u0e0a\u0e49 \u0e04\u0e48\u0e32\u0e2a\u0e48\u0e07\u0e1e\u0e31\u0e2a\u0e14\u0e38, \u0e04\u0e48\u0e32\u0e44\u0e1b\u0e23\u0e29\u0e13\u0e35\u0e22\u0e4c <code>\u0e04\u0e48\u0e32\u0e44\u0e1b\u0e23\u0e29\u0e13\u0e35\u0e22\u0e4c\u0e41\u0e25\u0e30\u0e04\u0e48\u0e32\u0e02\u0e19\u0e2a\u0e48\u0e07</code> \u0e04\u0e48\u0e32\u0e19\u0e49\u0e33\u0e21\u0e31\u0e19\u0e23\u0e16 <code>\u0e04\u0e48\u0e32\u0e19\u0e49\u0e33\u0e21\u0e31\u0e19\u0e41\u0e25\u0e30\u0e22\u0e32\u0e19\u0e1e\u0e32\u0e2b\u0e19\u0e30</code> \u0e04\u0e48\u0e32\u0e42\u0e17\u0e23\u0e28\u0e31\u0e1e\u0e17\u0e4c, \u0e2d\u0e34\u0e19\u0e40\u0e17\u0e2d\u0e23\u0e4c\u0e40\u0e19\u0e47\u0e15 <code>\u0e04\u0e48\u0e32\u0e2a\u0e37\u0e48\u0e2d\u0e2a\u0e32\u0e23\u0e41\u0e25\u0e30\u0e42\u0e17\u0e23\u0e04\u0e21\u0e19\u0e32\u0e04\u0e21</code> \u0e04\u0e48\u0e32\u0e44\u0e1f, \u0e04\u0e48\u0e32\u0e19\u0e49\u0e33 <code>\u0e04\u0e48\u0e32\u0e2a\u0e32\u0e18\u0e32\u0e23\u0e13\u0e39\u0e1b\u0e42\u0e20\u0e04</code> \u0e04\u0e48\u0e32\u0e0b\u0e2d\u0e1f\u0e15\u0e4c\u0e41\u0e27\u0e23\u0e4c, License <code>\u0e04\u0e48\u0e32\u0e43\u0e0a\u0e49\u0e08\u0e48\u0e32\u0e22\u0e0b\u0e2d\u0e1f\u0e15\u0e4c\u0e41\u0e27\u0e23\u0e4c</code> \u0e40\u0e07\u0e34\u0e19\u0e40\u0e14\u0e37\u0e2d\u0e19\u0e1e\u0e19\u0e31\u0e01\u0e07\u0e32\u0e19 <code>\u0e04\u0e48\u0e32\u0e43\u0e0a\u0e49\u0e08\u0e48\u0e32\u0e22\u0e1a\u0e38\u0e04\u0e25\u0e32\u0e01\u0e23</code> \u0e04\u0e48\u0e32\u0e42\u0e06\u0e29\u0e13\u0e32, \u0e01\u0e32\u0e23\u0e15\u0e25\u0e32\u0e14 <code>\u0e04\u0e48\u0e32\u0e42\u0e06\u0e29\u0e13\u0e32\u0e41\u0e25\u0e30\u0e01\u0e32\u0e23\u0e15\u0e25\u0e32\u0e14</code>"},{"location":"docs/accounting/journals/#_8","title":"\u0e14\u0e39\u0e23\u0e32\u0e22\u0e01\u0e32\u0e23\u0e17\u0e35\u0e48\u0e1a\u0e31\u0e19\u0e17\u0e36\u0e01\u0e41\u0e25\u0e49\u0e27","text":"<p>\u0e44\u0e1b\u0e17\u0e35\u0e48 \u0e2a\u0e21\u0e38\u0e14\u0e23\u0e32\u0e22\u0e27\u0e31\u0e19 (\u0e2b\u0e19\u0e49\u0e32\u0e2b\u0e25\u0e31\u0e01) \u0e08\u0e30\u0e40\u0e2b\u0e47\u0e19: - \u0e15\u0e32\u0e23\u0e32\u0e07\u0e23\u0e32\u0e22\u0e01\u0e32\u0e23\u0e17\u0e31\u0e49\u0e07\u0e2b\u0e21\u0e14\u0e40\u0e23\u0e35\u0e22\u0e07\u0e15\u0e32\u0e21\u0e27\u0e31\u0e19\u0e17\u0e35\u0e48 - \u0e22\u0e2d\u0e14\u0e23\u0e27\u0e21 \u0e40\u0e14\u0e1a\u0e34\u0e15 (\u0e23\u0e32\u0e22\u0e08\u0e48\u0e32\u0e22) vs \u0e40\u0e04\u0e23\u0e14\u0e34\u0e15 (\u0e08\u0e48\u0e32\u0e22\u0e2d\u0e2d\u0e01\u0e08\u0e32\u0e01) - \u0e04\u0e25\u0e34\u0e01\u0e44\u0e2d\u0e04\u0e2d\u0e19\u0e40\u0e2d\u0e01\u0e2a\u0e32\u0e23\u0e40\u0e1e\u0e37\u0e48\u0e2d\u0e40\u0e1b\u0e34\u0e14\u0e43\u0e1a\u0e40\u0e2a\u0e23\u0e47\u0e08\u0e17\u0e35\u0e48\u0e41\u0e19\u0e1a\u0e44\u0e27\u0e49</p>"},{"location":"docs/modules/getting-started/","title":"\ud83d\ude80 \u0e40\u0e23\u0e34\u0e48\u0e21\u0e15\u0e49\u0e19\u0e43\u0e0a\u0e49\u0e07\u0e32\u0e19 Micro Account","text":""},{"location":"docs/modules/getting-started/#_1","title":"\u0e04\u0e27\u0e32\u0e21\u0e15\u0e49\u0e2d\u0e07\u0e01\u0e32\u0e23\u0e02\u0e2d\u0e07\u0e23\u0e30\u0e1a\u0e1a","text":"<p>\u0e04\u0e27\u0e32\u0e21\u0e15\u0e49\u0e2d\u0e07\u0e01\u0e32\u0e23\u0e1e\u0e37\u0e49\u0e19\u0e10\u0e32\u0e19</p> <ul> <li>Browser: Chrome, Firefox, Edge \u0e40\u0e27\u0e2d\u0e23\u0e4c\u0e0a\u0e31\u0e48\u0e19\u0e25\u0e48\u0e32\u0e2a\u0e38\u0e14</li> <li>Internet connection (\u0e23\u0e30\u0e1a\u0e1a\u0e17\u0e33\u0e07\u0e32\u0e19\u0e1a\u0e19 Cloud)</li> <li>\u0e1a\u0e31\u0e0d\u0e0a\u0e35 Google Workspace (\u0e2a\u0e33\u0e2b\u0e23\u0e31\u0e1a \u0e2d\u0e31\u0e1b\u0e42\u0e2b\u0e25\u0e14\u0e40\u0e2d\u0e01\u0e2a\u0e32\u0e23)</li> </ul>"},{"location":"docs/modules/getting-started/#_2","title":"\u0e27\u0e34\u0e18\u0e35\u0e40\u0e02\u0e49\u0e32\u0e2a\u0e39\u0e48\u0e23\u0e30\u0e1a\u0e1a","text":"<ol> <li>\u0e40\u0e1b\u0e34\u0e14 Browser \u0e44\u0e1b\u0e17\u0e35\u0e48 https://micro-account.vercel.app</li> <li>\u0e01\u0e23\u0e2d\u0e01 \u0e2d\u0e35\u0e40\u0e21\u0e25 \u0e41\u0e25\u0e30 \u0e23\u0e2b\u0e31\u0e2a\u0e1c\u0e48\u0e32\u0e19 \u0e17\u0e35\u0e48\u0e1c\u0e39\u0e49\u0e14\u0e39\u0e41\u0e25\u0e23\u0e30\u0e1a\u0e1a\u0e21\u0e2d\u0e1a\u0e43\u0e2b\u0e49</li> <li>\u0e2a\u0e16\u0e32\u0e19\u0e30 Account \u0e15\u0e49\u0e2d\u0e07\u0e40\u0e1b\u0e47\u0e19 Active \u0e16\u0e36\u0e07\u0e08\u0e30\u0e40\u0e02\u0e49\u0e32\u0e44\u0e14\u0e49 (\u0e2b\u0e32\u0e01\u0e22\u0e31\u0e07\u0e44\u0e21\u0e48\u0e44\u0e14\u0e49\u0e23\u0e31\u0e1a\u0e01\u0e32\u0e23\u0e2d\u0e19\u0e38\u0e21\u0e31\u0e15\u0e34 \u0e15\u0e34\u0e14\u0e15\u0e48\u0e2d\u0e1c\u0e39\u0e49\u0e14\u0e39\u0e41\u0e25\u0e23\u0e30\u0e1a\u0e1a)</li> </ol>"},{"location":"docs/modules/getting-started/#_3","title":"\u0e41\u0e1c\u0e19\u0e1c\u0e31\u0e07\u0e40\u0e21\u0e19\u0e39\u0e23\u0e30\u0e1a\u0e1a","text":"<pre><code>Micro Account\n\u251c\u2500\u2500 \ud83c\udfe0 \u0e2b\u0e19\u0e49\u0e32\u0e41\u0e23\u0e01 (Dashboard)\n\u251c\u2500\u2500 \ud83d\udcc4 \u0e43\u0e1a\u0e40\u0e2a\u0e19\u0e2d\u0e23\u0e32\u0e04\u0e32\n\u251c\u2500\u2500 \ud83e\uddfe \u0e43\u0e1a\u0e41\u0e08\u0e49\u0e07\u0e2b\u0e19\u0e35\u0e49\n\u251c\u2500\u2500 \ud83d\udd01 \u0e23\u0e2d\u0e1a\u0e1a\u0e34\u0e25\u0e2d\u0e31\u0e15\u0e42\u0e19\u0e21\u0e31\u0e15\u0e34\n\u251c\u2500\u2500 \ud83d\udcb3 \u0e01\u0e32\u0e23\u0e0a\u0e33\u0e23\u0e30\u0e40\u0e07\u0e34\u0e19\n\u251c\u2500\u2500 \ud83d\udcdc \u0e43\u0e1a\u0e2a\u0e33\u0e04\u0e31\u0e0d\u0e08\u0e48\u0e32\u0e22\n\u251c\u2500\u2500 \ud83d\udcd2 \u0e2a\u0e21\u0e38\u0e14\u0e23\u0e32\u0e22\u0e27\u0e31\u0e19\n\u251c\u2500\u2500 \ud83d\udce6 \u0e04\u0e25\u0e31\u0e07\u0e2a\u0e34\u0e19\u0e04\u0e49\u0e32\n\u251c\u2500\u2500 \ud83d\udc65 \u0e25\u0e39\u0e01\u0e04\u0e49\u0e32/\u0e04\u0e39\u0e48\u0e04\u0e49\u0e32\n\u251c\u2500\u2500 \ud83d\udcca \u0e23\u0e32\u0e22\u0e07\u0e32\u0e19\u0e20\u0e32\u0e29\u0e35\n\u251c\u2500\u2500 \u2699\ufe0f \u0e15\u0e31\u0e49\u0e07\u0e04\u0e48\u0e32\u0e23\u0e30\u0e1a\u0e1a\n\u2514\u2500\u2500 [Admin]\n    \u251c\u2500\u2500 \ud83d\udc64 \u0e08\u0e31\u0e14\u0e01\u0e32\u0e23\u0e2a\u0e21\u0e32\u0e0a\u0e34\u0e01\n    \u2514\u2500\u2500 \ud83d\udd10 \u0e08\u0e31\u0e14\u0e01\u0e32\u0e23\u0e2a\u0e34\u0e17\u0e18\u0e34\u0e4c\n</code></pre>"},{"location":"docs/modules/setup-google/","title":"\ud83d\udd10 \u0e01\u0e32\u0e23\u0e15\u0e31\u0e49\u0e07\u0e04\u0e48\u0e32 Google Workspace API","text":"<p>\u0e04\u0e39\u0e48\u0e21\u0e37\u0e2d\u0e19\u0e35\u0e49\u0e08\u0e30\u0e19\u0e33\u0e1e\u0e32\u0e04\u0e38\u0e13\u0e15\u0e31\u0e49\u0e07\u0e04\u0e48\u0e32 Google Cloud APIs \u0e2a\u0e33\u0e2b\u0e23\u0e31\u0e1a Micro Account \u0e15\u0e31\u0e49\u0e07\u0e41\u0e15\u0e48\u0e40\u0e23\u0e34\u0e48\u0e21\u0e15\u0e49\u0e19\u0e08\u0e19\u0e16\u0e36\u0e07\u0e01\u0e32\u0e23\u0e43\u0e0a\u0e49\u0e07\u0e32\u0e19\u0e08\u0e23\u0e34\u0e07\u0e1a\u0e19 Vercel</p>"},{"location":"docs/modules/setup-google/#_1","title":"\ud83d\udccb \u0e20\u0e32\u0e1e\u0e23\u0e27\u0e21\u0e2a\u0e34\u0e48\u0e07\u0e17\u0e35\u0e48\u0e15\u0e49\u0e2d\u0e07\u0e17\u0e33","text":"<pre><code>1. \u0e2a\u0e23\u0e49\u0e32\u0e07 Google Cloud Project (\u0e2b\u0e23\u0e37\u0e2d\u0e43\u0e0a\u0e49\u0e2d\u0e31\u0e19\u0e40\u0e14\u0e34\u0e21)\n2. \u0e40\u0e1b\u0e34\u0e14\u0e43\u0e0a\u0e49\u0e07\u0e32\u0e19 APIs \u0e17\u0e35\u0e48\u0e08\u0e33\u0e40\u0e1b\u0e47\u0e19\n3. \u0e2a\u0e23\u0e49\u0e32\u0e07 OAuth 2.0 Client ID\n4. \u0e2a\u0e23\u0e49\u0e32\u0e07 API Key\n5. \u0e43\u0e2a\u0e48\u0e04\u0e48\u0e32 Environment Variables \u0e43\u0e19 Vercel\n6. \u0e17\u0e14\u0e2a\u0e2d\u0e1a\u0e23\u0e30\u0e1a\u0e1a\n</code></pre>"},{"location":"docs/modules/setup-google/#1-google-cloud-project","title":"\u0e02\u0e31\u0e49\u0e19\u0e15\u0e2d\u0e19\u0e17\u0e35\u0e48 1 \u2014 Google Cloud Project","text":"<p>\u0e43\u0e0a\u0e49 Project \u0e17\u0e35\u0e48\u0e21\u0e35\u0e2d\u0e22\u0e39\u0e48\u0e41\u0e25\u0e49\u0e27\u0e44\u0e14\u0e49</p> <p>\u0e16\u0e49\u0e32\u0e21\u0e35 Google Cloud Project \u0e2d\u0e22\u0e39\u0e48\u0e41\u0e25\u0e49\u0e27\u0e02\u0e49\u0e32\u0e21\u0e02\u0e31\u0e49\u0e19\u0e15\u0e2d\u0e19\u0e19\u0e35\u0e49\u0e44\u0e14\u0e49\u0e40\u0e25\u0e22</p> <ol> <li>\u0e44\u0e1b\u0e17\u0e35\u0e48 console.cloud.google.com</li> <li>\u0e04\u0e25\u0e34\u0e01 \"Select a project\" \u0e17\u0e35\u0e48\u0e21\u0e38\u0e21\u0e1a\u0e19\u0e0b\u0e49\u0e32\u0e22</li> <li>\u0e04\u0e25\u0e34\u0e01 \"New Project\" \u0e2b\u0e23\u0e37\u0e2d\u0e40\u0e25\u0e37\u0e2d\u0e01 Project \u0e17\u0e35\u0e48\u0e21\u0e35\u0e2d\u0e22\u0e39\u0e48</li> </ol>"},{"location":"docs/modules/setup-google/#2-apis","title":"\u0e02\u0e31\u0e49\u0e19\u0e15\u0e2d\u0e19\u0e17\u0e35\u0e48 2 \u2014 \u0e40\u0e1b\u0e34\u0e14\u0e43\u0e0a\u0e49\u0e07\u0e32\u0e19 APIs","text":"<p>\u0e44\u0e1b\u0e17\u0e35\u0e48 APIs &amp; Services \u2192 Library \u0e41\u0e25\u0e49\u0e27\u0e04\u0e49\u0e19\u0e2b\u0e32\u0e41\u0e25\u0e30 Enable:</p> API \u0e43\u0e0a\u0e49\u0e17\u0e33\u0e2d\u0e30\u0e44\u0e23 Google Drive API \u0e2d\u0e48\u0e32\u0e19/\u0e41\u0e2a\u0e14\u0e07\u0e44\u0e1f\u0e25\u0e4c\u0e43\u0e1a\u0e40\u0e2a\u0e23\u0e47\u0e08 Google Picker API UI \u0e40\u0e25\u0e37\u0e2d\u0e01\u0e44\u0e1f\u0e25\u0e4c\u0e08\u0e32\u0e01 Drive Gmail API \u0e2a\u0e48\u0e07\u0e2d\u0e35\u0e40\u0e21\u0e25\u0e1a\u0e34\u0e25\u0e2d\u0e31\u0e15\u0e42\u0e19\u0e21\u0e31\u0e15\u0e34 Google Sheets API Export \u0e23\u0e32\u0e22\u0e07\u0e32\u0e19\u0e1a\u0e31\u0e0d\u0e0a\u0e35 Google Calendar API \u0e41\u0e08\u0e49\u0e07\u0e40\u0e15\u0e37\u0e2d\u0e19\u0e23\u0e2d\u0e1a\u0e1a\u0e34\u0e25"},{"location":"docs/modules/setup-google/#3-oauth-consent-screen","title":"\u0e02\u0e31\u0e49\u0e19\u0e15\u0e2d\u0e19\u0e17\u0e35\u0e48 3 \u2014 OAuth Consent Screen","text":"<p>\u0e15\u0e49\u0e2d\u0e07\u0e17\u0e33\u0e01\u0e48\u0e2d\u0e19\u0e2a\u0e23\u0e49\u0e32\u0e07 Client ID</p> <ol> <li>\u0e44\u0e1b\u0e17\u0e35\u0e48 APIs &amp; Services \u2192 OAuth consent screen</li> <li>\u0e40\u0e25\u0e37\u0e2d\u0e01 User Type: Internal (\u0e43\u0e0a\u0e49\u0e40\u0e09\u0e1e\u0e32\u0e30\u0e43\u0e19\u0e2d\u0e07\u0e04\u0e4c\u0e01\u0e23)</li> <li>\u0e01\u0e23\u0e2d\u0e01\u0e02\u0e49\u0e2d\u0e21\u0e39\u0e25:</li> <li>App name: <code>Micro Account</code></li> <li>User support email: \u0e2d\u0e35\u0e40\u0e21\u0e25\u0e2d\u0e07\u0e04\u0e4c\u0e01\u0e23\u0e02\u0e2d\u0e07\u0e04\u0e38\u0e13</li> <li>\u0e01\u0e14 Save and Continue \u0e08\u0e19\u0e04\u0e23\u0e1a\u0e17\u0e38\u0e01 Step</li> </ol>"},{"location":"docs/modules/setup-google/#4-oauth-20-client-id","title":"\u0e02\u0e31\u0e49\u0e19\u0e15\u0e2d\u0e19\u0e17\u0e35\u0e48 4 \u2014 \u0e2a\u0e23\u0e49\u0e32\u0e07 OAuth 2.0 Client ID","text":"<ol> <li>\u0e44\u0e1b\u0e17\u0e35\u0e48 APIs &amp; Services \u2192 Credentials</li> <li>\u0e04\u0e25\u0e34\u0e01 + Create Credentials \u2192 OAuth 2.0 Client ID</li> <li>Application type: Web application</li> <li>Name: <code>Micro Account Web</code></li> <li>\u0e40\u0e1e\u0e34\u0e48\u0e21 Authorized JavaScript origins:    <pre><code>https://your-project.vercel.app\nhttp://localhost:3000\n</code></pre></li> <li>\u0e04\u0e25\u0e34\u0e01 Create \u2192 Copy Client ID \u0e17\u0e35\u0e48\u0e44\u0e14\u0e49</li> </ol>"},{"location":"docs/modules/setup-google/#5-api-key","title":"\u0e02\u0e31\u0e49\u0e19\u0e15\u0e2d\u0e19\u0e17\u0e35\u0e48 5 \u2014 \u0e2a\u0e23\u0e49\u0e32\u0e07 API Key","text":"<ol> <li>\u0e04\u0e25\u0e34\u0e01 + Create Credentials \u2192 API Key</li> <li>Copy API Key \u0e17\u0e35\u0e48\u0e44\u0e14\u0e49</li> <li>\u0e04\u0e25\u0e34\u0e01 Edit API Key \u0e40\u0e1e\u0e37\u0e48\u0e2d\u0e08\u0e33\u0e01\u0e31\u0e14\u0e01\u0e32\u0e23\u0e43\u0e0a\u0e49\u0e07\u0e32\u0e19:</li> </ol> <p>Website restrictions: <pre><code>https://your-project.vercel.app/*\nhttp://localhost:3000/*\n</code></pre></p> <p>API restrictions \u2192 Restrict key \u2192 \u0e40\u0e25\u0e37\u0e2d\u0e01: - \u2705 Google Drive API - \u2705 Google Picker API</p> <ol> <li>\u0e01\u0e14 Save</li> </ol>"},{"location":"docs/modules/setup-google/#6-environment-variables-vercel","title":"\u0e02\u0e31\u0e49\u0e19\u0e15\u0e2d\u0e19\u0e17\u0e35\u0e48 6 \u2014 \u0e43\u0e2a\u0e48 Environment Variables \u0e43\u0e19 Vercel","text":"<ol> <li>\u0e40\u0e1b\u0e34\u0e14 vercel.com/dashboard</li> <li>\u0e40\u0e25\u0e37\u0e2d\u0e01 Project micro-account</li> <li>\u0e44\u0e1b\u0e17\u0e35\u0e48 Settings \u2192 Environment Variables</li> <li>\u0e40\u0e1e\u0e34\u0e48\u0e21\u0e04\u0e48\u0e32\u0e15\u0e48\u0e2d\u0e44\u0e1b\u0e19\u0e35\u0e49\u0e17\u0e35\u0e25\u0e30\u0e15\u0e31\u0e27:</li> </ol> Variable Name \u0e04\u0e48\u0e32\u0e17\u0e35\u0e48\u0e15\u0e49\u0e2d\u0e07\u0e43\u0e2a\u0e48 Environment <code>DATABASE_URL</code> PostgreSQL connection string \u0e08\u0e32\u0e01 Neon All <code>NEXT_PUBLIC_GOOGLE_CLIENT_ID</code> Client ID \u0e08\u0e32\u0e01\u0e02\u0e31\u0e49\u0e19\u0e15\u0e2d\u0e19\u0e17\u0e35\u0e48 4 All <code>GOOGLE_CLIENT_SECRET</code> Client Secret \u0e08\u0e32\u0e01\u0e02\u0e31\u0e49\u0e19\u0e15\u0e2d\u0e19\u0e17\u0e35\u0e48 4 All <code>NEXT_PUBLIC_GOOGLE_API_KEY</code> API Key \u0e08\u0e32\u0e01\u0e02\u0e31\u0e49\u0e19\u0e15\u0e2d\u0e19\u0e17\u0e35\u0e48 5 All <code>GMAIL_FROM</code> \u0e2d\u0e35\u0e40\u0e21\u0e25\u0e2d\u0e07\u0e04\u0e4c\u0e01\u0e23\u0e17\u0e35\u0e48\u0e43\u0e0a\u0e49\u0e2a\u0e48\u0e07 All <code>GMAIL_APP_PASSWORD</code> App Password \u0e08\u0e32\u0e01 Google Account All <ol> <li>\u0e01\u0e14 Save \u0e41\u0e25\u0e49\u0e27\u0e01\u0e14 Redeploy</li> </ol> <p>\u0e27\u0e34\u0e18\u0e35\u0e2a\u0e23\u0e49\u0e32\u0e07 Gmail App Password</p> <ol> <li>\u0e44\u0e1b\u0e17\u0e35\u0e48 myaccount.google.com/apppasswords</li> <li>\u0e15\u0e49\u0e2d\u0e07\u0e40\u0e1b\u0e34\u0e14 2-Step Verification \u0e01\u0e48\u0e2d\u0e19</li> <li>Select app: Mail / Select device: Other \u2192 \u0e1e\u0e34\u0e21\u0e1e\u0e4c <code>Micro Account</code></li> <li>Copy \u0e23\u0e2b\u0e31\u0e2a 16 \u0e15\u0e31\u0e27\u0e2d\u0e31\u0e01\u0e29\u0e23\u0e17\u0e35\u0e48\u0e44\u0e14\u0e49 \u2192 \u0e43\u0e2a\u0e48\u0e43\u0e19 <code>GMAIL_APP_PASSWORD</code></li> </ol>"},{"location":"docs/modules/setup-google/#7","title":"\u0e02\u0e31\u0e49\u0e19\u0e15\u0e2d\u0e19\u0e17\u0e35\u0e48 7 \u2014 \u0e17\u0e14\u0e2a\u0e2d\u0e1a","text":"<p>\u0e2b\u0e25\u0e31\u0e07 Redeploy \u0e41\u0e25\u0e49\u0e27 \u0e17\u0e14\u0e2a\u0e2d\u0e1a\u0e17\u0e35\u0e48:</p> <ol> <li>\u0e44\u0e1b\u0e17\u0e35\u0e48 \u0e2a\u0e21\u0e38\u0e14\u0e23\u0e32\u0e22\u0e27\u0e31\u0e19 \u2192 \u0e25\u0e07\u0e1a\u0e31\u0e0d\u0e0a\u0e35\u0e43\u0e2b\u0e21\u0e48</li> <li>\u0e2a\u0e48\u0e27\u0e19 \"\ud83d\udcce \u0e41\u0e19\u0e1a\u0e43\u0e1a\u0e40\u0e2a\u0e23\u0e47\u0e08\" \u0e08\u0e30\u0e21\u0e35\u0e1b\u0e38\u0e48\u0e21 \"\u0e40\u0e25\u0e37\u0e2d\u0e01\u0e08\u0e32\u0e01 Google Drive\"</li> <li>\u0e04\u0e25\u0e34\u0e01\u0e1b\u0e38\u0e48\u0e21 \u2192 Login Google \u2192 \u0e40\u0e25\u0e37\u0e2d\u0e01\u0e44\u0e1f\u0e25\u0e4c \u2192 \u0e41\u0e19\u0e1a\u0e2a\u0e33\u0e40\u0e23\u0e47\u0e08 \u2705</li> </ol>"},{"location":"docs/modules/setup-google/#_2","title":"\ud83d\udd27 \u0e41\u0e01\u0e49\u0e1b\u0e31\u0e0d\u0e2b\u0e32\u0e17\u0e35\u0e48\u0e1e\u0e1a\u0e1a\u0e48\u0e2d\u0e22","text":""},{"location":"docs/modules/setup-google/#google-drive-error-client-id","title":"\u0e1b\u0e38\u0e48\u0e21 Google Drive \u0e02\u0e36\u0e49\u0e19 Error \"Client ID \u0e44\u0e21\u0e48\u0e16\u0e39\u0e01\u0e15\u0e49\u0e2d\u0e07\"","text":"<ul> <li>\u0e15\u0e23\u0e27\u0e08\u0e2a\u0e2d\u0e1a\u0e27\u0e48\u0e32 Authorized JavaScript origins \u0e21\u0e35 URL \u0e02\u0e2d\u0e07 Vercel \u0e16\u0e39\u0e01\u0e15\u0e49\u0e2d\u0e07</li> <li>\u0e23\u0e2d 5 \u0e19\u0e32\u0e17\u0e35\u0e2b\u0e25\u0e31\u0e07 Save \u0e43\u0e19 Google Cloud (Settings \u0e43\u0e0a\u0e49\u0e40\u0e27\u0e25\u0e32 propagate)</li> </ul>"},{"location":"docs/modules/setup-google/#picker-error-access-blocked","title":"\u0e1b\u0e38\u0e48\u0e21\u0e40\u0e1b\u0e34\u0e14 Picker \u0e41\u0e25\u0e49\u0e27\u0e02\u0e36\u0e49\u0e19 Error \"Access blocked\"","text":"<ul> <li>OAuth Consent Screen \u0e15\u0e49\u0e2d\u0e07\u0e40\u0e1b\u0e47\u0e19 Internal \u0e2b\u0e23\u0e37\u0e2d App \u0e15\u0e49\u0e2d\u0e07\u0e1c\u0e48\u0e32\u0e19 Verification</li> <li>\u0e15\u0e23\u0e27\u0e08\u0e2a\u0e2d\u0e1a\u0e27\u0e48\u0e32 User \u0e17\u0e35\u0e48 Login \u0e40\u0e1b\u0e47\u0e19 Email \u0e43\u0e19 Organization \u0e40\u0e14\u0e35\u0e22\u0e27\u0e01\u0e31\u0e19</li> </ul>"},{"location":"docs/modules/setup-google/#_3","title":"\u0e44\u0e1f\u0e25\u0e4c\u0e41\u0e19\u0e1a\u0e41\u0e25\u0e49\u0e27\u0e41\u0e15\u0e48\u0e40\u0e1b\u0e34\u0e14\u0e44\u0e21\u0e48\u0e44\u0e14\u0e49","text":"<ul> <li>\u0e15\u0e23\u0e27\u0e08\u0e2a\u0e2d\u0e1a\u0e27\u0e48\u0e32\u0e44\u0e1f\u0e25\u0e4c\u0e43\u0e19 Google Drive \u0e21\u0e35\u0e2a\u0e34\u0e17\u0e18\u0e34\u0e4c \"Anyone with the link can view\"</li> </ul>"}]}