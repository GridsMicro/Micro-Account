# ============================================================
# Micro Account — Environment Variables Template
# บริษัท ไมโครทรอนิก (ไทยแลนด์) จำกัด
# ============================================================
# คัดลอกไฟล์นี้เป็น .env.local แล้วใส่ค่าจริงของคุณ
# cp .env.example .env.local
# ⚠️ ห้าม Commit .env.local ขึ้น GitHub เด็ดขาด!
# ============================================================

# -----------------------------------------------
# 1. DATABASE (Neon PostgreSQL)
# สร้างได้ที่: https://neon.tech
# -----------------------------------------------
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require

# -----------------------------------------------
# 2. GOOGLE OAUTH 2.0 (Google Drive File Picker)
# สร้างได้ที่: https://console.cloud.google.com/apis/credentials
# → Create Credentials → OAuth 2.0 Client ID → Web application
# -----------------------------------------------
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your_client_secret
GOOGLE_REFRESH_TOKEN=1//your_refresh_token
GOOGLE_REDIRECT_URI=https://your-domain.vercel.app/api/auth/callback/google

# -----------------------------------------------
# 3. GOOGLE API KEY (Google Picker API)
# สร้างได้ที่: https://console.cloud.google.com/apis/credentials
# → Create Credentials → API Key
# ⚠️ จำกัด Key ให้ใช้ได้แค่ Google Drive API + Google Picker API
# -----------------------------------------------
NEXT_PUBLIC_GOOGLE_API_KEY=AIzaSy_your_api_key

# -----------------------------------------------
# 4. GMAIL (ส่งอีเมลอัตโนมัติ)
# สร้าง App Password: https://myaccount.google.com/apppasswords
# ต้องเปิด 2-Step Verification ก่อน
# -----------------------------------------------
GMAIL_FROM=noreply@your-domain.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# -----------------------------------------------
# 5. NEXTAUTH (ระบบ Login จริง)
# สร้าง Secret ด้วย: openssl rand -base64 32
# Session Duration: เป็นวินาที (24 ชม = 86400 วินาที)
# -----------------------------------------------
NEXTAUTH_URL=https://your-domain.vercel.app
NEXTAUTH_SECRET=your_random_secret_32_chars
SESSION_MAX_AGE=86400

# -----------------------------------------------
# 6. SEED DATA (สำหรับเตรียมข้อมูลเริ่มต้น)
# ⚠️ ใช้เพื่อสร้างผู้ใช้ admin เท่านั้น
# ⚠️ หลังจากสร้างแล้วควรแก้ไขรหัสผ่าน และลบค่าเหล่านี้
# -----------------------------------------------
# Email ของ Admin (ค่าเริ่มต้น: admin@microtronic.biz)
SEED_ADMIN_EMAIL=admin@microtronic.biz

# ชื่อ Admin (ค่าเริ่มต้น: Administrator)
SEED_ADMIN_NAME=Administrator

# รหัสผ่าน Admin (ค่าเริ่มต้น: admin123) ⚠️ ใช้ตัวอักษรที่ปลอดภัย
SEED_ADMIN_PASSWORD=admin123

# Role ของ Admin (ค่าเริ่มต้น: Administrator)
SEED_ADMIN_ROLE=Administrator
